# Copy to .env.local and fill in. App runs without these (returns stubbed replies) so you can test the UI.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Cost caps (optional — sane defaults in code)
# Keep these two equal — the server enforces DAILY_MSG_CAP; NEXT_PUBLIC_DAILY_MSG_CAP is
# just the client-side pre-check (saves a round-trip) and drifts silently if changed alone.
DAILY_MSG_CAP=30
NEXT_PUBLIC_DAILY_MSG_CAP=30
GLOBAL_DAILY_SPEND_USD=15
